rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Clients can read and write their own folder — MUST come first
    match /clients/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }

    // Admin can access everything
    match /{allPaths=**} {
      allow read, write: if request.auth != null
        && request.auth.token.email == "office@globalvisajourneys.com";
    }

  }
}